# --- OpenWA ---
# Inside the docker network, OpenWA is reachable at http://openwa:2785
OPENWA_API_URL=http://openwa:2785

# Create this once via the OpenWA dashboard (http://localhost:2785) before
# `docker compose up`. Settings -> API Keys -> Create. The langgraph-app will
# refuse to boot if this is left as the placeholder, so an unfilled value
# fails loudly instead of silently.
OPENWA_API_KEY=replace-me-before-first-boot

# Name of the WhatsApp session you create in the OpenWA dashboard.
OPENWA_SESSION_ID=default

# --- ngrok ---
# Free token: https://dashboard.ngrok.com/get-started/your-authtoken
# Without this, ngrok has a 2-hour session limit and shows a warning banner.
NGROK_AUTHTOKEN=3DnSlmIHPvkzmxOa1kKZnwB4Qe0_6RVyLQWrkhNH6uV38arg2

# --- App ---
LOG_LEVEL=INFO